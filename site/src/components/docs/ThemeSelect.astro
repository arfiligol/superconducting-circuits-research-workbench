---
import { Icon } from "@astrojs/starlight/components";

const label = Astro.locals.t("themeSelect.accessibleLabel");
const paletteLabel = "Select docs palette";
const paletteChoices = [
  { value: "research-mint", label: "Mint", title: "Research Mint", swatch: "#6bd1c7" },
  { value: "tech-slate", label: "Slate", title: "Tech Slate", swatch: "#3182ce" },
  { value: "nordic-calm", label: "Nordic", title: "Nordic Calm", swatch: "#88c0d0" },
  { value: "coffee-terminal", label: "Coffee", title: "Coffee Terminal", swatch: "#d08770" },
] as const;
const choices = [
  { value: "dark", label: Astro.locals.t("themeSelect.dark"), icon: "moon" },
  { value: "light", label: Astro.locals.t("themeSelect.light"), icon: "sun" },
  { value: "auto", label: Astro.locals.t("themeSelect.auto"), icon: "laptop" },
] as const;
---

<starlight-theme-select class="docs-appearance-select">
  <div class="appearance-control">
    <details class="palette-menu">
      <summary class="palette-menu__summary" aria-label={paletteLabel} title={paletteLabel}>
        <span class="palette-menu__swatch" data-palette-current-swatch></span>
        <span class="palette-menu__label" data-palette-current-label>Mint</span>
      </summary>
      <div class="palette-menu__panel" role="group" aria-label={paletteLabel}>
        {
          paletteChoices.map((choice) => (
            <button
              type="button"
              class="palette-menu__button"
              data-palette-choice={choice.value}
              data-palette-label={choice.label}
              aria-pressed="false"
              aria-label={choice.title}
              title={choice.title}
            >
              <span class="palette-menu__button-swatch" style={`--palette-swatch: ${choice.swatch}`}></span>
              <span>{choice.label}</span>
            </button>
          ))
        }
      </div>
    </details>
    <div class="theme-control" role="group" aria-label={label}>
      {
        choices.map((choice) => (
          <button
            type="button"
            class="theme-control__button"
            data-theme-choice={choice.value}
            aria-pressed="false"
            aria-label={choice.label}
            title={choice.label}
          >
            <Icon name={choice.icon} size="1rem" />
            <span>{choice.label}</span>
          </button>
        ))
      }
    </div>
  </div>
</starlight-theme-select>

<script is:inline>
  StarlightThemeProvider.updatePickers();
  (() => {
    const allowed = new Set(["research-mint", "tech-slate", "nordic-calm", "coffee-terminal"]);
    const stored = localStorage.getItem("docs-palette");
    document.documentElement.dataset.docsPalette = allowed.has(stored) ? stored : "research-mint";
  })();
</script>

<script>
  type Theme = "auto" | "dark" | "light";
  type Palette = "coffee-terminal" | "nordic-calm" | "research-mint" | "tech-slate";
  declare const StarlightThemeProvider: {
    updatePickers(theme?: Theme): void;
  };

  const storageKey = "starlight-theme";
  const paletteStorageKey = "docs-palette";
  const paletteLabels: Record<Palette, string> = {
    "coffee-terminal": "Coffee",
    "nordic-calm": "Nordic",
    "research-mint": "Mint",
    "tech-slate": "Slate",
  };
  const parseTheme = (theme: unknown): Theme =>
    theme === "auto" || theme === "dark" || theme === "light" ? theme : "auto";
  const parsePalette = (palette: unknown): Palette =>
    palette === "coffee-terminal" ||
    palette === "nordic-calm" ||
    palette === "research-mint" ||
    palette === "tech-slate"
      ? palette
      : "research-mint";
  const loadTheme = (): Theme =>
    parseTheme(typeof localStorage !== "undefined" && localStorage.getItem(storageKey));
  const loadPalette = (): Palette =>
    parsePalette(typeof localStorage !== "undefined" && localStorage.getItem(paletteStorageKey));
  const getPreferredColorScheme = (): Theme =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== "undefined") {
      localStorage.setItem(storageKey, theme === "light" || theme === "dark" ? theme : "");
    }
  }

  function storePalette(palette: Palette): void {
    if (typeof localStorage !== "undefined") {
      localStorage.setItem(paletteStorageKey, palette);
    }
  }

  function updateButtons(theme: Theme): void {
    document.querySelectorAll<HTMLElement>("starlight-theme-select").forEach((picker) => {
      picker.querySelectorAll<HTMLButtonElement>("[data-theme-choice]").forEach((button) => {
        const active = button.dataset.themeChoice === theme;
        button.setAttribute("aria-pressed", String(active));
        button.toggleAttribute("data-active", active);
      });
    });
  }

  function updatePaletteButtons(palette: Palette): void {
    document.querySelectorAll<HTMLElement>("starlight-theme-select").forEach((picker) => {
      picker.dataset.currentPalette = palette;
      picker.querySelectorAll<HTMLButtonElement>("[data-palette-choice]").forEach((button) => {
        const active = button.dataset.paletteChoice === palette;
        button.setAttribute("aria-pressed", String(active));
        button.toggleAttribute("data-active", active);
      });
      picker.querySelectorAll<HTMLElement>("[data-palette-current-label]").forEach((labelElement) => {
        labelElement.textContent = paletteLabels[palette];
      });
    });
  }

  function onThemeChange(theme: Theme): void {
    StarlightThemeProvider.updatePickers(theme);
    document.documentElement.dataset.theme = theme === "auto" ? getPreferredColorScheme() : theme;
    storeTheme(theme);
    updateButtons(theme);
  }

  function onPaletteChange(palette: Palette): void {
    document.documentElement.dataset.docsPalette = palette;
    storePalette(palette);
    updatePaletteButtons(palette);
  }

  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (loadTheme() === "auto") onThemeChange("auto");
  });

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super();
      onThemeChange(loadTheme());
      onPaletteChange(loadPalette());
      this.querySelectorAll<HTMLButtonElement>("[data-theme-choice]").forEach((button) => {
        button.addEventListener("click", () => onThemeChange(parseTheme(button.dataset.themeChoice)));
      });
      this.querySelectorAll<HTMLButtonElement>("[data-palette-choice]").forEach((button) => {
        button.addEventListener("click", () => {
          onPaletteChange(parsePalette(button.dataset.paletteChoice));
          button.closest("details")?.removeAttribute("open");
        });
      });
    }
  }

  if (!customElements.get("starlight-theme-select")) {
    customElements.define("starlight-theme-select", StarlightThemeSelect);
  }
</script>

<style>
  .appearance-control {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .palette-menu {
    position: relative;
  }

  .palette-menu__summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.35rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0 0.7rem;
    color: var(--sl-color-gray-2);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 88%, var(--sl-color-gray-6));
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--sl-color-white) 8%, transparent);
    cursor: pointer;
    user-select: none;
  }

  .palette-menu__summary::marker,
  .palette-menu__summary::-webkit-details-marker {
    display: none;
    content: "";
  }

  .palette-menu__summary:hover {
    color: var(--sl-color-text-accent);
    border-color: var(--sl-color-accent-high);
  }

  .palette-menu__summary:focus-visible {
    outline: 2px solid var(--sl-color-accent-high);
    outline-offset: 2px;
  }

  .palette-menu__swatch,
  .palette-menu__button-swatch {
    border: 1px solid color-mix(in srgb, var(--docs-rule) 75%, transparent);
    border-radius: 999px;
    background: var(--docs-accent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--sl-color-white) 22%, transparent);
  }

  .palette-menu__swatch {
    width: 0.85rem;
    height: 0.85rem;
  }

  .palette-menu__panel {
    position: absolute;
    z-index: 20;
    inset-block-start: calc(100% + 0.45rem);
    inset-inline-end: 0;
    display: grid;
    gap: 0.25rem;
    min-width: 11rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 0.35rem;
    background: var(--sl-color-bg-nav);
    box-shadow: var(--sl-shadow-lg);
  }

  .palette-menu:not([open]) .palette-menu__panel {
    display: none;
  }

  .palette-menu__button {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.1rem;
    border: 0;
    border-radius: 0.5rem;
    padding: 0 0.65rem;
    color: var(--sl-color-gray-2);
    background: transparent;
    font: inherit;
    font-size: var(--sl-text-sm);
    text-align: start;
    cursor: pointer;
  }

  .palette-menu__button:hover {
    background: color-mix(in srgb, var(--sl-color-accent-low) 50%, transparent);
    color: var(--sl-color-text-accent);
  }

  .palette-menu__button:focus-visible {
    outline: 2px solid var(--sl-color-accent-high);
    outline-offset: 2px;
  }

  .palette-menu__button[data-active] {
    color: var(--docs-on-accent);
    background: var(--docs-control-active-bg);
  }

  .palette-menu__button-swatch {
    width: 0.75rem;
    height: 0.75rem;
    background: var(--palette-swatch);
  }

  .theme-control {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    padding: 0.1875rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 88%, var(--sl-color-gray-6));
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--sl-color-white) 8%, transparent);
  }

  .theme-control__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-width: 2.35rem;
    min-height: 2rem;
    border: 0;
    border-radius: 999px;
    padding: 0 0.65rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    font: inherit;
    font-size: var(--sl-text-sm);
    line-height: 1;
    cursor: pointer;
  }

  .theme-control__button:hover {
    color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-gray-5) 54%, transparent);
  }

  .theme-control__button:focus-visible {
    outline: 2px solid var(--sl-color-accent-high);
    outline-offset: 2px;
  }

  .theme-control__button[data-active] {
    color: var(--docs-on-accent);
    background: var(--docs-control-active-bg);
    box-shadow: var(--sl-shadow-sm);
  }

  @media (max-width: 38rem) {
    .appearance-control {
      gap: 0.3rem;
    }

    .palette-menu__summary {
      min-width: 2.35rem;
      padding: 0;
    }

    .palette-menu__label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .theme-control__button span {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>
