# Network / app
SC_APP_HOST=127.0.0.1
SC_APP_PORT=8000

# Persistence
SC_DATABASE_PATH=data/database.db
SC_AUDIT_DATABASE_PATH=data/audit-log.db
SC_TRACE_STORE_ROOT=data/trace_store
SC_STAGING_ROOT=data/staging
SC_ARTIFACTS_ROOT=data/artifacts

# Auth / sessions
# Development-only placeholders. Non-development startup rejects obvious defaults.
SC_SESSION_SECRET=change-me-session-secret
SC_BOOTSTRAP_ADMIN_USERNAME=admin
SC_BOOTSTRAP_ADMIN_PASSWORD=change-me-bootstrap-password
