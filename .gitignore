# --- Project Specific ---
# Simulation Outputs (don't track generated plots in root-ish dirs)
# Keep them in specific output folders if needed, or track them if they are assets.
# But generally avoid tracking temporary simulation results.
*.png
*.svg
*.pdf

# Exception for documentation assets (if you want to strictly track doc images)
!docs/assets/*.png
!docs/assets/*.svg
!site/public/favicon.svg
!site/public/assets/*.png
!site/public/assets/*.svg

# Sandbox - Track source, ignore disposable outputs
sandbox/**/*.csv
sandbox/**/*.tsv
sandbox/**/*.png
sandbox/**/*.svg
sandbox/**/*.pdf
sandbox/**/*.jpg
sandbox/**/*.jpeg
sandbox/**/*.webp
sandbox/**/*.gif
sandbox/**/*.log
sandbox/**/*.tmp
sandbox/**/*.temp

# Local history
.history/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# --- Data ---
# Preprocessed or raw data that shouldn't be committed
data/processed/
data/raw/
data/database.db
data/database.db-*
data/trace_store/
data/**/*.zarr/
app/backend/data/test-runtime/
# Keep gitkeep or README if they exist to guard structure, but ignore files
# data/*
# !data/.gitkeep

# Persistence
*.db
*.sqlite
*.sqlite3
data/huey/

# Generated package metadata can appear inside workspace packages too
app/backend/**/*.egg-info/
core/python/**/*.egg-info/

# Local Playwright runtime outputs/logs
.playwright-mcp/
output/
output/playwright/
.next/
test-results/
tmp/
tmp/rewrite_logs/
tmp/rewrite_pids/
